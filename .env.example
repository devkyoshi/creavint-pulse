# Database
DATABASE_URL=postgresql://creavint:creavint@localhost:5432/creavint

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
# Run BullMQ workers inside the API process (true for pilot/dev, false to run `pnpm --filter api workers` separately)
WORKERS_INLINE=true

# Auth
JWT_SECRET=change_me_in_production
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_NAME=cv_session

# Seed admin (db:seed)
SEED_ADMIN_EMAIL=admin@creavint.com
SEED_ADMIN_PASSWORD=admin1234

# LLM — paid provider (Claude). For free tier, set GROQ_API_KEY or GEMINI_API_KEY and
# configure llm_provider via Admin → System Config.
ANTHROPIC_API_KEY=
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001

# LLM — free tier alternatives (configure active provider in Admin → System Config)
# Groq: free tier at console.groq.com (llama-3.3-70b-versatile, llama-3.1-8b-instant)
GROQ_API_KEY=
# Google Gemini: free tier at aistudio.google.com (gemini-2.5-flash / gemini-3.5-flash)
GEMINI_API_KEY=
# Embeddings (OpenAI-compatible endpoint; leave empty to use deterministic dev-only embeddings)
EMBEDDINGS_API_URL=https://api.openai.com/v1/embeddings
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# Image generation — paid provider (Replicate / Flux Schnell)
REPLICATE_API_KEY=
# Image generation — free stock photo alternatives (configure active provider in Admin → System Config)
# Pexels: free API at pexels.com/api
PEXELS_API_KEY=
# Unsplash: free API at unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GA4_PROPERTY_ID=
GSC_SERVICE_ACCOUNT_JSON=
ADSENSE_PUBLISHER_ID=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
ORIGIN_IP=

# DataForSEO — paid keyword research
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Keywords — free tier alternative (configure active provider in Admin → System Config)
# Serper.dev: free tier 2500 searches/month at serper.dev
SERPER_API_KEY=

# Git content store (leave GIT_REPO_URL empty to operate on the local sites/ dir without push — dev mode)
GIT_REPO_URL=
GIT_SERVICE_ACCOUNT_KEY=

# Origin VPS
ORIGIN_VPS_HOST=
ORIGIN_VPS_USER=root
ORIGIN_VPS_SSH_KEY=
NGINX_VHOSTS_DIR=/etc/nginx/sites-available

# Alerts
SLACK_WEBHOOK_URL=

# Hugo
HUGO_BINARY_PATH=hugo
SITES_REPO_LOCAL_PATH=./sites
HUGO_TEMPLATES_PATH=./hugo-templates
