{
  "name": "creavint-pulse",
  "private": true,
  "version": "0.1.0",
  "description": "Creavint Pulse — automated content monetization platform (internal staff tool)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @creavint/backend dev",
